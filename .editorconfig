[*.{fs,fsi,fsx}]
# Default is 120
max_line_length = 120
# Default is false
fsharp_space_before_colon = false
# Default is cramped in v7, aligned in v8-alpha
fsharp_multiline_bracket_style = aligned
# Default is character_width
fsharp_array_or_list_multiline_formatter = number_of_items
# Default is 1
fsharp_max_array_or_list_number_of_items = 8
